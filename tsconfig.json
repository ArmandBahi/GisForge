{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@app/*": [
        "src/app/*"
      ],
      "@app/shared/ui/button": [
        "./src/app/shared/ui/button/src/index.ts"
      ],
      "@app/shared/ui/utils": [
        "./src/app/shared/ui/utils/src/index.ts"
      ],
      "@app/shared/ui/input": [
        "./src/app/shared/ui/input/src/index.ts"
      ],
      "@app/shared/ui/form-field": [
        "./src/app/shared/ui/form-field/src/index.ts"
      ],
      "@app/shared/ui/label": [
        "./src/app/shared/ui/label/src/index.ts"
      ],
      "@app/shared/ui/skeleton": [
        "./src/app/shared/ui/skeleton/src/index.ts"
      ],
      "@app/shared/ui/separator": [
        "./src/app/shared/ui/separator/src/index.ts"
      ],
      "@app/shared/ui/table": [
        "./src/app/shared/ui/table/src/index.ts"
      ],
      "@app/shared/ui/dialog": [
        "./src/app/shared/ui/dialog/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
